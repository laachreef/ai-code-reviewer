{
  "name": "ai-code-reviewer",
  "version": "0.1.0-beta",
  "description": "Application de revue de code automatisée par IA multi-agents",
  "author": "Achref TLILI <ac.tlili@groupeonepoint.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --port 5181 --strictPort\" \"tsc -p electron -w\" \"wait-on tcp:5181 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && tsc -p electron && electron-builder",
    "build:win": "vite build && tsc -p electron && cross-env CSC_SKIP_SIGNING=true electron-builder --win"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "electron-is-dev": "^3.0.1",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^1.7.0",
    "ngrok": "^5.0.0-beta.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "vite": "^5.4.10",
    "wait-on": "^9.0.4"
  }
}
